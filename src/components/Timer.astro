---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Time Timer Pro | Digital v3">
<div class="flex flex-col items-center justify-center min-h-screen p-8 bg-slate-50 overflow-hidden">
  
  <button id="fs-toggle" class="fixed top-6 right-6 p-2 text-slate-400 hover:text-slate-600 transition-colors z-50">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
  </button>

  <div class="relative w-80 h-80 bg-white rounded-full shadow-2xl flex items-center justify-center border-8 border-slate-200">
    <div class="absolute inset-4 border-2 border-dashed border-slate-100 rounded-full"></div>

    <svg class="absolute w-full h-full" viewBox="0 0 100 100">
      <g id="tick-marks"></g>
      <g id="tick-numbers"></g>
      
      <circle
        id="timer-disk"
        cx="50" cy="50" r="25"
        fill="transparent"
        stroke="#ef4444"
        stroke-width="50"
        stroke-dasharray="157"
        stroke-dashoffset="0"
        opacity="0.9" 
        style="transform: scaleX(-1) rotate(270deg); transform-origin: center;"
        class="timer-transition"
      ></circle>

      <line 
        id="second-hand" 
        x1="50" y1="50" x2="50" y2="7" 
        stroke="#94a3b8" 
        stroke-width="0.7" 
        stroke-linecap="round"
        style="transform-origin: center; opacity: 0;"
      />
    </svg>
    <div class="z-10 w-4 h-4 bg-slate-800 rounded-full shadow-md"></div>
  </div>

  <div class="mt-12 space-y-8 w-full max-w-md text-center">
    <div id="time-display" class="text-6xl font-mono font-bold text-slate-700 tracking-tight transition-colors duration-300">
      25:00
    </div>

    <div class="flex gap-4 justify-center">
      <button id="start-btn" class="bg-emerald-500 text-white w-40 py-4 rounded-2xl font-bold transition-all active:scale-95 shadow-lg text-lg flex items-center justify-center">Start</button>
      <button id="reset-btn" class="bg-slate-200 text-slate-700 w-40 py-4 rounded-2xl font-bold hover:bg-slate-300 transition-colors text-lg flex items-center justify-center">Nullstill</button>
    </div>

    <div class="pt-8 border-t border-slate-200 space-y-6">
      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-slate-400 font-bold mb-4">Sett tid (Min : Sek)</p>
        <div class="flex gap-2 justify-center items-center">
          <input type="number" id="custom-min" placeholder="Min" min="0" max="60" class="w-20 p-3 border-2 border-slate-200 rounded-xl text-center font-bold focus:border-emerald-500 outline-none" />
          <span class="font-bold text-slate-300">:</span>
          <input type="number" id="custom-sec" placeholder="Sek" min="0" max="59" class="w-20 p-3 border-2 border-slate-200 rounded-xl text-center font-bold focus:border-emerald-500 outline-none" />
          <button id="set-btn" class="bg-slate-800 text-white px-5 py-3 rounded-xl font-bold hover:bg-slate-700 ml-2">Sett</button>
        </div>
      </div>

      <div class="flex gap-3 justify-center">
        {['#ef4444', '#f97316', '#facc15', '#10b981', '#3b82f6', '#a855f7'].map(color => (
          <button class="color-picker w-10 h-10 rounded-full border-4 border-white shadow-sm transition-transform active:scale-90" data-color={color} style={`background-color: ${color}`} />
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  /* Gjer at blinkinga blir tydelegare med raud farge */
  .animate-pulse.text-red-600 {
    animation: pulse-red 1s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes pulse-red {
    0%, 100% { opacity: 1; color: #dc2626; }
    50% { opacity: 0.3; color: #ef4444; }
  }
</style>

<script>
  let totalSeconds: number = 25 * 60;
  let timeLeft: number = totalSeconds;
  let timerId: number | undefined;
  let endTime: number | null = null;
  let wakeLock: any = null;
  const fullDash = 157;
  
  // DIGITAL LYD (Mixkit 1000)
  const alarmSound = new Audio("https://assets.mixkit.co/active_storage/sfx/1000/1000-preview.mp3");
  alarmSound.loop = true;
  alarmSound.volume = 0.8;

  const disk = document.getElementById("timer-disk") as unknown as SVGCircleElement;
  const secondHand = document.getElementById("second-hand") as unknown as SVGLineElement;
  const display = document.getElementById("time-display") as HTMLElement;
  const startBtn = document.getElementById("start-btn") as HTMLButtonElement;
  const resetBtn = document.getElementById("reset-btn") as HTMLButtonElement;
  const customMinInput = document.getElementById("custom-min") as HTMLInputElement;
  const customSecInput = document.getElementById("custom-sec") as HTMLInputElement;
  const setBtn = document.getElementById("set-btn") as HTMLButtonElement;
  const fsBtn = document.getElementById("fs-toggle") as HTMLButtonElement;
  const tickGroup = document.getElementById("tick-marks") as unknown as SVGGElement;
  const tickNumbers = document.getElementById("tick-numbers") as unknown as SVGGElement;

  async function startWakeLock() {
    if ("wakeLock" in navigator) {
      try {
        wakeLock = await (navigator as any).wakeLock.request("screen");
      } catch (err) { console.warn("Wake Lock feila"); }
    }
  }

  function updateVisuals(smooth: boolean = true) {
    disk.style.transition = smooth ? "stroke-dashoffset 1.1s linear" : "none";
    const mins = Math.floor(timeLeft / 60);
    const secs = timeLeft % 60;
    display.textContent = `${mins.toString().padStart(2, "0")}:${secs.toString().padStart(2, "0")}`;

    const offset = fullDash * (1 - (timeLeft / 3600));
    disk.setAttribute("stroke-dashoffset", offset.toString());

    // Sekundvisar utan animasjon for å hindre "spoling"
    const rotation = -(secs * 6);
    secondHand.style.transition = "none";
    secondHand.style.transform = `rotate(${rotation}deg)`;
    secondHand.style.opacity = (timerId && timeLeft > 0) ? "1" : "0";
  }

  function tick() {
    if (endTime) {
      const now = Date.now();
      timeLeft = Math.max(0, Math.round((endTime - now) / 1000));
      updateVisuals(true);

      if (timeLeft <= 0) {
        // TIDA ER UTE
        clearInterval(timerId);
        timerId = undefined;
        endTime = null;
        
        alarmSound.play().catch(() => {});
        display.classList.add("text-red-600", "animate-pulse");
        
        startBtn.textContent = "Start";
        startBtn.classList.remove("bg-orange-500");
        startBtn.classList.add("bg-emerald-500");
      }
    }
  }

  function startTimer() {
    // Preparer lyd for iOS/iPad
    alarmSound.play().then(() => { alarmSound.pause(); alarmSound.currentTime = 0; }).catch(() => {});
    
    // Fjern blink viss vi startar på nytt
    display.classList.remove("text-red-600", "animate-pulse");
    alarmSound.pause();
    alarmSound.currentTime = 0;

    if (timerId) {
      // PAUSE
      clearInterval(timerId);
      timerId = undefined;
      endTime = null;
      startBtn.textContent = "Fortsett";
      startBtn.classList.remove("bg-orange-500");
      startBtn.classList.add("bg-emerald-500");
    } else if (timeLeft > 0) {
      // START / FORTSETT
      startWakeLock();
      endTime = Date.now() + (timeLeft * 1000);
      startBtn.textContent = "Pause";
      startBtn.classList.remove("bg-emerald-500");
      startBtn.classList.add("bg-orange-500");
      timerId = window.setInterval(tick, 1000);
      updateVisuals(false);
    }
  }

  function stopTimer() {
    // RESET-funksjon
    clearInterval(timerId);
    timerId = undefined;
    endTime = null;
    
    alarmSound.pause();
    alarmSound.currentTime = 0;
    display.classList.remove("text-red-600", "animate-pulse");

    startBtn.textContent = "Start";
    startBtn.classList.remove("bg-orange-500");
    startBtn.classList.add("bg-emerald-500");
    
    if (wakeLock) { wakeLock.release().then(() => { wakeLock = null; }); }
  }

  function createTicks() {
    tickGroup.innerHTML = ''; tickNumbers.innerHTML = '';
    for (let i = 0; i <= 60; i++) {
      const angle = (270 + i * 6) * (Math.PI / 180); 
      const isFiveMin = i % 5 === 0;
      if (i < 60) {
        const innerRadius = isFiveMin ? 42 : 45; 
        const x1 = 50 + innerRadius * Math.cos(angle);
        const y1 = 50 + innerRadius * Math.sin(angle);
        const x2 = 50 + 50 * Math.cos(angle);
        const y2 = 50 + 50 * Math.sin(angle);
        const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
        line.setAttribute("x1", x1.toString()); line.setAttribute("y1", y1.toString());
        line.setAttribute("x2", x2.toString()); line.setAttribute("y2", y2.toString());
        line.setAttribute("stroke", isFiveMin ? "#94a3b8" : "#cbd5e1");
        line.setAttribute("stroke-width", isFiveMin ? "1" : "0.5");
        tickGroup.appendChild(line);
      }
      if (isFiveMin && i > 0 && i < 60) {
        const textRadius = 38;
        const tx = 50 + textRadius * Math.cos(angle);
        const ty = 50 + textRadius * Math.sin(angle);
        const text = document.createElementNS("http://www.w3.org/2000/svg", "text");
        text.setAttribute("x", tx.toString()); text.setAttribute("y", ty.toString());
        text.setAttribute("fill", "#000"); text.setAttribute("font-size", "4.5");
        text.setAttribute("font-weight", "900"); text.setAttribute("text-anchor", "middle");
        text.setAttribute("dominant-baseline", "middle");
        text.textContent = (60 - i).toString();
        tickNumbers.appendChild(text);
      }
    }
  }

  startBtn.addEventListener("click", startTimer);
  resetBtn.addEventListener("click", () => { stopTimer(); timeLeft = totalSeconds; updateVisuals(false); });
  
  setBtn.addEventListener("click", () => {
    const m = parseInt(customMinInput.value) || 0;
    const s = parseInt(customSecInput.value) || 0;
    const total = (m * 60) + s;
    if (total > 0 && total <= 3600) {
      stopTimer();
      totalSeconds = total;
      timeLeft = totalSeconds;
      updateVisuals(false);
    }
  });

  document.querySelectorAll(".color-picker").forEach(btn => {
    btn.addEventListener("click", () => {
      const color = btn.getAttribute("data-color");
      if (color) disk.setAttribute("stroke", color);
    });
  });

  fsBtn.addEventListener("click", () => {
    if (!document.fullscreenElement) document.documentElement.requestFullscreen().catch(() => {});
    else document.exitFullscreen();
  });

  document.addEventListener("visibilitychange", () => {
    if (document.visibilityState === "visible" && timerId) {
      startWakeLock();
      tick(); 
    }
  });

  createTicks();
  updateVisuals(false);
</script>
</Layout>