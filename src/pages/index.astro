---
import Layout from '../layouts/Layout.astro';
import Timer from '../components/Timer.astro';
---

<Layout title="Min Time Timer | Fokusverktøy">
	<main>
		<Timer />
	</main>
</Layout>

<style>
	/* Her kan du leggje til spesifikke stilar for forsida viss nødvendig, 
	   men sidan Timer-komponenten er "self-contained", treng vi nesten ingenting her. */
	main {
		width: 100%;
		max-width: 100vw;
		overflow: hidden;
	}
</style>