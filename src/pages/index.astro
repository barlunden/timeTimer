---
// Astro Component Script (Server-side)
import "../styles/global.css";
---

<head>
  <meta charset="UTF-8" />
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
  />
  <title>Time Timer Pro</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap"
    rel="stylesheet"
  />

  <style>
    body {
      -webkit-tap-highlight-color: transparent;
      user-select: none;
      font-family: "Inter", sans-serif;
    }
    /* Gjer at skiva glir mjukt når den tel ned, men vi kan slå det av ved behov */
    .timer-transition {
      transition: stroke-dashoffset 1s linear;
    }
  </style>
</head>

<div
  class="flex flex-col items-center justify-center min-h-screen bg-slate-50 p-8"
>
  <div
    class="relative w-80 h-80 bg-white rounded-full shadow-2xl flex items-center justify-center border-8 border-slate-200"
  >
    <div
      class="absolute inset-4 border-2 border-dashed border-slate-100 rounded-full"
    >
    </div>

    <svg class="absolute w-full h-full -rotate-90" viewBox="0 0 100 100">
      <g id="tick-marks"></g>
      <g id="tick-numbers"></g>
      <circle
  id="timer-disk"
  cx="50" cy="50" r="25"
  fill="transparent"
  stroke="#ef4444"
  stroke-width="50"
  stroke-dasharray="157"
  stroke-dashoffset="0"
  opacity="0.93" 
  style="transform: scaleX(-1) rotate(180deg); transform-origin: center;"
  class="timer-transition"
></circle>
    </svg>

    <div class="z-10 w-4 h-4 bg-slate-800 rounded-full shadow-md"></div>
  </div>

  <div class="mt-12 space-y-6 w-full max-w-md text-center">
    <div id="time-display" class="text-5xl font-mono font-bold text-slate-700">
      25:00
    </div>

    <div class="flex gap-4 justify-center">
      <button
        id="start-btn"
        class="bg-emerald-500 text-white px-8 py-3 rounded-2xl font-bold transition-transform active:scale-95 shadow-lg"
        >Start</button
      >
      <button
        id="reset-btn"
        class="bg-slate-200 text-slate-700 px-8 py-3 rounded-2xl font-bold"
        >Nullstill</button
      >
    </div>

    <div class="pt-6 border-t border-slate-200">
      <p class="text-xs uppercase tracking-widest text-slate-400 mb-3">
        Still inn tid
      </p>
      <div class="flex gap-2 justify-center" id="pro-controls">
        <input
          type="number"
          id="custom-min"
          placeholder="25"
          min="1"
          max="60"
          class="w-20 p-2 border-2 border-slate-200 rounded-lg text-center focus:border-emerald-500 outline-none"
        />
        <button
          id="set-btn"
          class="bg-amber-400 text-amber-900 px-4 py-2 rounded-lg font-bold hover:bg-amber-500"
          >Sett tid</button
        >
      </div>
      <div class="pt-6 border-t border-slate-200">
        <p class="text-xs uppercase tracking-widest text-slate-400 mb-3">
          Vel farge
        </p>
        <div class="flex gap-3 justify-center">
          <button
            class="color-picker w-8 h-8 rounded-full bg-red-500 border-2 border-transparent focus:border-slate-400"
            data-color="#ef4444"></button>
          <button
            class="color-picker w-8 h-8 rounded-full bg-orange-500 border-2 border-transparent focus:border-slate-400"
            data-color="#f97316"></button>
          <button
            class="color-picker w-8 h-8 rounded-full bg-yellow-400 border-2 border-transparent focus:border-slate-400"
            data-color="#facc15"></button>
          <button
            class="color-picker w-8 h-8 rounded-full bg-emerald-500 border-2 border-transparent focus:border-slate-400"
            data-color="#10b981"></button>
          <button
            class="color-picker w-8 h-8 rounded-full bg-blue-500 border-2 border-transparent focus:border-slate-400"
            data-color="#3b82f6"></button>
          <button
            class="color-picker w-8 h-8 rounded-full bg-purple-500 border-2 border-transparent focus:border-slate-400"
            data-color="#a855f7"></button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Variablar med typar
  let totalTime: number = 25 * 60;
  let timeLeft: number = totalTime;
  let timerId: number | undefined;
  const fullDash = 157;
  const alarmSound = new Audio(
    "https://actions.google.com/sounds/v1/alarms/beep_short.ogg",
  );
  

  // Hent element
  const disk = document.getElementById(
    "timer-disk",
  ) as unknown as SVGCircleElement;
  const display = document.getElementById("time-display") as HTMLElement;
  const startBtn = document.getElementById("start-btn") as HTMLButtonElement;
  const resetBtn = document.getElementById("reset-btn") as HTMLButtonElement;
  const customInput = document.getElementById("custom-min") as HTMLInputElement;
  const setBtn = document.getElementById("set-btn") as HTMLButtonElement;
  const tickGroup = document.getElementById(
    "tick-marks",
  ) as unknown as SVGGElement;
  const tickNumbers = document.getElementById("tick-numbers") as unknown as SVGGElement;
  const colorButtons = document.querySelectorAll(".color-picker");

  colorButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const color = (btn as HTMLButtonElement).getAttribute("data-color");
      if (color) {
        disk.setAttribute("stroke", color);
      }
    });
  });
  function updateVisuals(smooth: boolean = true) {
    disk.style.transition = smooth ? "stroke-dashoffset 1s linear" : "none";

    const mins = Math.floor(timeLeft / 60);
    const secs = timeLeft % 60;
    display.textContent = `${mins.toString().padStart(2, "0")}:${secs.toString().padStart(2, "0")}`;

    // Her er den magiske formelen for Time Timer:
    // Vi vil at offset skal vere 0 (full sirkel) når vi har 60 minutt,
    // og 157 (tom sirkel) når vi har 0 minutt.
    const maxSeconds = 60 * 60;
    const percentageLeft = timeLeft / maxSeconds;
    const offset = fullDash * (1 - percentageLeft);

    disk.setAttribute("stroke-dashoffset", offset.toString());
  }

  function startTimer() {
    alarmSound.play();
    alarmSound.pause();
    alarmSound.currentTime = 0;

    if (timerId) {
      clearInterval(timerId);
      timerId = undefined;
      startBtn.textContent = "Fortsett";
      startBtn.classList.replace("bg-orange-500", "bg-emerald-500");
    } else {
      startBtn.textContent = "Pause";
      startBtn.classList.add("bg-orange-500");
      timerId = window.setInterval(() => {
        if (timeLeft > 0) {
          timeLeft--;
          updateVisuals(true);
        } else {
          stopTimer();
          alarmSound.play();
          alert("Tiden er ute!");
        }
      }, 1000);
    }
  }

  function stopTimer() {
    clearInterval(timerId);
    timerId = undefined;
    startBtn.textContent = "Start";
    startBtn.classList.remove("bg-orange-500");
  }

  function createTicks() {
  tickGroup.innerHTML = '';
  tickNumbers.innerHTML = '';

  for (let i = 0; i <= 60; i++) {
    // Vi startar på 270 grader (toppen i dette spegla systemet) 
    // og legg til vinkelen for å gå med klokka
    const angle = (i * 6) * (Math.PI / 180);
    const isFiveMin = i % 5 === 0;
    
    // 1. Strekane (som før)
    if (i < 60) {
      const innerRadius = isFiveMin ? 42 : 45; 
      const x1 = 50 + innerRadius * Math.cos(angle);
      const y1 = 50 + innerRadius * Math.sin(angle);
      const x2 = 50 + 50 * Math.cos(angle);
      const y2 = 50 + 50 * Math.sin(angle);

      const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
      line.setAttribute("x1", x1.toString());
      line.setAttribute("y1", y1.toString());
      line.setAttribute("x2", x2.toString());
      line.setAttribute("y2", y2.toString());
      line.setAttribute("stroke", isFiveMin ? "#94a3b8" : "#cbd5e1");
      line.setAttribute("stroke-width", isFiveMin ? "1" : "0.5");
      tickGroup.appendChild(line);
    }

    // 2. Tala (Motsatt rekkefølge: 55, 50, 45...)
    if (isFiveMin && i > 0 && i < 60) {
      const textRadius = 38;
      const tx = 50 + textRadius * Math.cos(angle);
      const ty = 50 + textRadius * Math.sin(angle);

      const text = document.createElementNS("http://www.w3.org/2000/svg", "text");
      text.setAttribute("x", tx.toString());
      text.setAttribute("y", ty.toString());
      text.setAttribute("fill", "#000");
      text.setAttribute("font-size", "4");
      text.setAttribute("font-weight", "900");
      text.setAttribute("text-anchor", "middle");
      text.setAttribute("dominant-baseline", "middle");

      text.setAttribute("transform", `rotate(90, ${tx}, ${ty})`);
      
      // Her snur vi rekkefølga!
      text.textContent = (60 - i).toString();
      tickNumbers.appendChild(text);
    }
  }


}

  // Event Listeners
  startBtn.addEventListener("click", startTimer);

  resetBtn.addEventListener("click", () => {
    stopTimer();
    timeLeft = totalTime;
    updateVisuals(false);
  });

  setBtn.addEventListener("click", () => {
    const val = parseInt(customInput.value);
    if (val > 0 && val <= 60) {
      stopTimer();
      totalTime = val * 60;
      timeLeft = totalTime;
      updateVisuals(false);
    }
  });

  // Start
  createTicks();
  updateVisuals(false);

  let wakeLock: WakeLockSentinel | null = null;

  async function requestWakeLock() {
    try {
      if ("wakeLock" in navigator) {
        wakeLock = await navigator.wakeLock.request("screen");
      }
    } catch (err) {
      const error = err as Error;
      console.error(`${error.name}, ${error.message}`);
    }
  }

  function releaseWakeLock() {
    if (wakeLock !== null) {
      wakeLock.release();
      wakeLock = null;
    }
  }

  // Oppdater startTimer for å be om lås
  // Oppdater stopTimer for å sleppe låsen
</script>
